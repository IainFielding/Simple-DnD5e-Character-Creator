<nav class="creator-rail">
  <header class="creator-rail-brand">
    <span>{{localize "sogrom-dnd5e-character-creator.window.brand"}}</span>
  </header>

  <ol class="creator-rail-steps">
    {{#each rail}}
    <li class="creator-rail-step {{#if active}}is-active{{/if}} {{#if complete}}is-complete{{/if}} {{#unless reachable}}is-locked{{/unless}}">
      <button type="button" class="creator-rail-link" data-action="goto" data-index="{{index}}" {{#unless reachable}}disabled{{/unless}}>
        <span class="creator-rail-marker">
          {{#if complete}}<i class="fa-solid fa-check"></i>{{else}}{{ordinal}}{{/if}}
        </span>
        <span class="creator-rail-text">
          <span class="creator-rail-label">{{label}}</span>
          {{#if summary}}<span class="creator-rail-summary">{{summary}}</span>{{/if}}
        </span>
      </button>
    </li>
    {{/each}}
  </ol>

  <footer class="creator-rail-foot">
    <button type="button" class="creator-btn creator-btn-ghost" data-action="cancel">
      <i class="fa-solid fa-xmark"></i> {{cancelLabel}}
    </button>
  </footer>
</nav>
