{{!--
  The "rail": the top bar listing every step as a numbered marker the player can jump between.
  Each entry comes from the shell's #railContext() and carries flags that drive its CSS classes:
    active    – the step currently on screen        complete  – done (shows a tick instead of a number)
    reachable – earlier steps done, so it's clickable  applicable – shown but greyed (e.g. Spells for a non-caster)
  Clicking a marker fires data-action="goto" with its index; the shell handles the navigation.
--}}
<header class="creator-topbar">
  <div class="creator-topbar-brand">
    <span>{{localize "sogrom-dnd5e-character-creator.window.brand"}}</span>
    {{#if version}}<span class="creator-topbar-version">v{{version}}</span>{{/if}}
  </div>

  <ol class="creator-topbar-steps">
    {{#each rail}}
    <li class="creator-rail-step {{#if active}}is-active{{/if}} {{#if complete}}is-complete{{/if}} {{#unless applicable}}is-skipped{{/unless}} {{#unless reachable}}is-locked{{/unless}}">
      <button type="button" class="creator-rail-link" data-action="goto" data-index="{{index}}" {{#unless reachable}}disabled{{/unless}}>
        <span class="creator-rail-marker">
          {{#if complete}}<i class="fa-solid fa-check"></i>{{else}}{{#if applicable}}{{ordinal}}{{else}}<i class="fa-solid fa-minus"></i>{{/if}}{{/if}}
        </span>
        <span class="creator-rail-label">{{label}}</span>
      </button>
    </li>
    {{/each}}
  </ol>

  <div class="creator-topbar-foot">
    <button type="button" class="creator-btn creator-btn-ghost" data-action="cancel">
      <i class="fa-solid fa-xmark"></i> {{cancelLabel}}
    </button>
  </div>
</header>
