<section class="creator-choices">
  {{!-- Rich dnd5e item tooltip for any element backed by a compendium uuid. The
        `.loading[data-uuid]` placeholder is what dnd5e's tooltip observer fills in. --}}
  {{#*inline "itemTip"}} data-tooltip="<section class='loading' data-uuid='{{uuid}}'><i class='fas fa-spinner fa-spin-pulse'></i></section>" data-tooltip-class="dnd5e2 dnd5e-tooltip item-tooltip themed theme-light"{{/inline}}

  {{!-- One selectable option, rendered as a level-up-style card so the choice screen matches the
        level-up selections page. The image is optional — most creation choices (proficiencies,
        abilities, languages) are text-only, so those cards run compact; "choose a feature" picks
        carry an item image. --}}
  {{#*inline "choiceOption"}}
  <li>
    <button type="button"
            class="creator-choice-card {{#if isSelected}}is-selected{{/if}} {{#if recommended}}is-recommended{{/if}} {{#if disabled}}is-disabled{{/if}}"
            data-action="stepAction" data-step-action="pick-choice"
            data-choice-source="{{source}}" data-sel-key="{{selKey}}" data-key="{{key}}" data-count="{{count}}"
            {{#if disabled}}disabled data-tooltip="{{disabledReason}}"{{else}}{{#if uuid}}{{> itemTip uuid=uuid}}{{else}}{{#if recommendTip}} data-tooltip="{{recommendTip}}"{{/if}}{{/if}}{{/if}}>
      {{#if recommended}}<i class="creator-choice-card-star fa-solid fa-star" aria-hidden="true"></i>{{/if}}
      {{#if img}}<img class="creator-choice-card-img" src="{{img}}" alt="">{{/if}}
      <span class="creator-choice-card-name">{{label}}</span>
      {{#if isSelected}}<span class="creator-choice-card-check"><i class="fa-solid fa-check"></i></span>{{/if}}
    </button>
  </li>
  {{/inline}}

  {{#if isEmpty}}
  <div class="creator-pick-empty">
    <i class="fa-solid fa-list-check"></i>
    <h2>{{localize "sogrom-dnd5e-character-creator.step.choices.label"}}</h2>
    <p>{{localize "sogrom-dnd5e-character-creator.step.choices.none"}}</p>
  </div>
  {{else}}

  {{!-- Overall progress across every gating decision (equipment excluded). --}}
  {{#if total}}
  <div class="creator-choices-progress">
    <div class="creator-choices-progress-track">
      <div class="creator-choices-progress-bar {{#if allDone}}is-full{{/if}}" style="width: {{pct}}%"></div>
    </div>
    <span class="creator-choices-progress-label">{{localize "sogrom-dnd5e-character-creator.step.choices.decisions" done=done total=total}}</span>
  </div>
  {{/if}}

  {{!-- One guided checklist: every decision is an accordion row. The next unfinished row is
        expanded; completed rows collapse to a chip + tick. Equipment rows are optional. --}}
  <div class="creator-choices-list">
    {{#each decisions}}
    <div class="creator-decision {{#if complete}}is-complete{{/if}} {{#if open}}is-open{{/if}}">
      <button type="button" class="creator-decision-head"
              data-action="stepAction" data-step-action="toggle-decision" data-decision="{{key}}"
              aria-expanded="{{#if open}}true{{else}}false{{/if}}">
        <span class="creator-decision-status">
          {{#if complete}}<i class="fa-solid fa-check"></i>{{else}}<i class="fa-regular fa-circle"></i>{{/if}}
        </span>
        <span class="creator-decision-chip">
          {{#if sourceImg}}<img src="{{sourceImg}}" alt="">{{/if}}
          <span class="creator-decision-chip-name">{{sourceName}}</span>
        </span>
        <span class="creator-decision-title">{{title}}</span>
        {{#if statusLabel}}<span class="creator-decision-count {{#if complete}}is-complete{{/if}}">{{statusLabel}}</span>{{/if}}
        <i class="creator-decision-chevron fa-solid fa-chevron-down" aria-hidden="true"></i>
      </button>

      <div class="creator-decision-body" {{#unless open}}hidden{{/unless}}>
        {{#if hint}}<div class="creator-choice-hint">{{{hint}}}</div>{{/if}}
        {{#if emptyNote}}<p class="creator-choice-empty">{{emptyNote}}</p>{{/if}}

        {{#if groups}}
          {{#each groups}}
          <div class="creator-choice-group">
            <span class="creator-choice-group-label">{{label}}</span>
            <ul class="creator-choice-grid">
              {{#each options}}{{> choiceOption}}{{/each}}
            </ul>
          </div>
          {{/each}}
        {{else}}
          <ul class="creator-choice-grid">
            {{#each options}}{{> choiceOption}}{{/each}}
          </ul>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}
</section>
