<section class="creator-class {{#unless abilities.selected}}creator-class--solo{{/unless}}">
  <div class="creator-class-main">
    <div class="creator-toolbar">
      <label class="creator-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="search" data-creator-search autocomplete="off"
               placeholder="{{localize 'sogrom-dnd5e-character-creator.common.search'}}">
      </label>
      <span class="creator-count">{{localize "sogrom-dnd5e-character-creator.common.available"}}: {{count}}</span>
    </div>

    <div class="creator-grid">
      {{#each cards}}
      <button type="button" class="creator-card {{#if selected}}is-selected{{/if}}"
              data-action="stepAction" data-step-action="pick-origin"
              data-uuid="{{uuid}}" data-name="{{name}}">
        <img class="creator-card-img" src="{{img}}" alt="">
        <span class="creator-card-name">{{name}}</span>
        {{#if selected}}<span class="creator-card-tick"><i class="fa-solid fa-check"></i></span>{{/if}}
      </button>
      {{else}}
      <p class="creator-empty">{{localize "sogrom-dnd5e-character-creator.common.noEntries"}}</p>
      {{/each}}
    </div>

    {{#if hasSelection}}
    <aside class="creator-detail">
      <header class="creator-detail-head">
        <img class="creator-detail-img" src="{{detail.img}}" alt="">
        <h2>{{detail.name}}</h2>
      </header>
      <div class="creator-detail-body">{{{detail.enriched}}}</div>
    </aside>
    {{/if}}
  </div>

  {{#with abilities}}
  {{#if selected}}
  <aside class="creator-class-aside">
    <h2 class="creator-aside-title">{{localize "sogrom-dnd5e-character-creator.step.bgAbilities.label"}}</h2>
    {{#if hasAsi}}
    <p class="creator-asi-hint">
      {{localize "sogrom-dnd5e-character-creator.step.bgAbilities.hint" points=points cap=cap}}
    </p>

    <div class="creator-points">
      <span class="creator-points-value {{#if allSpent}}is-zero{{/if}}">{{remaining}}</span>
      <span class="creator-points-label">{{localize "sogrom-dnd5e-character-creator.step.abilities.pointsLeft"}}</span>
    </div>
    {{else}}
    <p class="creator-asi-hint">{{localize "sogrom-dnd5e-character-creator.step.bgAbilities.none"}}</p>
    {{/if}}

    <ul class="creator-ability-list">
      {{#each rows}}
      <li class="creator-ability-row {{#if locked}}is-locked{{/if}} {{#if bonus}}is-assigned{{/if}}">
        <span class="creator-ability-name">{{label}}</span>
        <div class="creator-stepper">
          <button type="button" class="creator-step-btn" data-action="stepAction" data-step-action="bg-ability-dec"
                  data-ability="{{key}}" {{#unless canDec}}disabled{{/unless}}>&minus;</button>
          <span class="creator-ability-score">
            {{total}}
            {{#if locked}}<i class="creator-ability-lock fa-solid fa-lock" title="{{localize 'sogrom-dnd5e-character-creator.step.bgAbilities.locked'}}"></i>{{/if}}
          </span>
          <button type="button" class="creator-step-btn" data-action="stepAction" data-step-action="bg-ability-inc"
                  data-ability="{{key}}" {{#unless canInc}}disabled{{/unless}}>+</button>
        </div>
        <span class="creator-ability-mod">{{modifier}}</span>
      </li>
      {{/each}}
    </ul>

    {{#if hasAsi}}
    <div class="creator-ability-actions">
      <button type="button" class="creator-btn creator-btn-ghost" data-action="stepAction" data-step-action="bg-ability-reset">
        <i class="fa-solid fa-rotate-left"></i> {{localize "sogrom-dnd5e-character-creator.common.reset"}}
      </button>
    </div>
    {{/if}}
  </aside>
  {{/if}}
  {{/with}}
</section>
