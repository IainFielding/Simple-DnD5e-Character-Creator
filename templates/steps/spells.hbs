{{!--
  The Spells step (creation): pick the cantrips and level-1 spells a spellcasting class knows. Two
  tabs (cantrips / level-1), a filterable list of the class's spells, and a running "picked" tally.
  Non-casters get a short "nothing to choose" message instead (the {{else}} of `isSpellcaster`).
  Data from spells-step.mjs context(); clicking a spell fires data-action="pick-spell".
--}}
<section class="creator-pick creator-spells creator-spells-browser">
  {{#if isSpellcaster}}
  <!-- Main column: intro, tabs, filters, and the spell list for the active tab -->
  <div class="creator-pick-side">
    <p class="levelup-spells-intro">{{intro}}</p>

    <div class="creator-spell-tabs">
      {{#if hasCantrips}}
      <button type="button" class="creator-spell-tab {{#if isCantripsTab}}is-active{{/if}} {{#if cantripsFull}}is-full{{/if}}"
              data-action="stepAction" data-step-action="spell-tab" data-tab="cantrips">
        {{localize "sogrom-dnd5e-character-creator.step.spells.cantrips"}}
        <span class="creator-spell-count">{{cantripCount}}/{{maxCantrips}}</span>
      </button>
      {{/if}}
      {{#if hasLevel1}}
      <button type="button" class="creator-spell-tab {{#if isLevel1Tab}}is-active{{/if}} {{#if spellsFull}}is-full{{/if}}"
              data-action="stepAction" data-step-action="spell-tab" data-tab="level1">
        {{localize "sogrom-dnd5e-character-creator.step.spells.level1"}}
        <span class="creator-spell-count">{{spellCount}}/{{maxSpells}}</span>
      </button>
      {{/if}}
    </div>

    <div class="creator-toolbar creator-toolbar--stacked">
      <div class="creator-spell-search-row">
        <label class="creator-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="search" data-creator-search autocomplete="off"
                  aria-label="{{localize 'sogrom-dnd5e-character-creator.common.search'}}"
                  placeholder="{{localize 'sogrom-dnd5e-character-creator.common.search'}}">
        </label>
        <div class="creator-spell-filters">
          {{#if isLevel1Tab}}
          <label class="creator-spell-filter">
            <i class="fa-solid fa-layer-group"></i>
            <select data-spell-filter-level aria-label="{{localize 'sogrom-dnd5e-character-creator.levelup.step.spells.filterLevelAria'}}">
              <option value="">{{localize "sogrom-dnd5e-character-creator.levelup.step.spells.filterAllLevels"}}</option>
              {{#each levelOptions}}<option value="{{value}}">{{label}}</option>{{/each}}
            </select>
          </label>
          {{/if}}
          <label class="creator-spell-filter">
            <i class="fa-solid fa-hat-wizard"></i>
            <select data-spell-filter-school aria-label="{{localize 'sogrom-dnd5e-character-creator.levelup.step.spells.filterSchoolAria'}}">
              <option value="">{{localize "sogrom-dnd5e-character-creator.levelup.step.spells.filterAllSchools"}}</option>
              {{#each schoolOptions}}<option value="{{value}}">{{label}}</option>{{/each}}
            </select>
          </label>
        </div>
      </div>
      <span class="creator-count">{{needLabel}}</span>
    </div>

    <ul class="creator-picklist">
      {{#each list}}
      <li>
        <button type="button"
                class="creator-pickrow {{#if active}}is-selected{{/if}} {{#if focused}}is-focused{{/if}} {{#if disabled}}is-disabled{{/if}}"
                data-action="stepAction" data-step-action="focus-spell"
                data-uuid="{{uuid}}" data-name="{{name}}" data-level="{{level}}" data-school="{{school}}"
                data-tooltip="{{ccItemTooltip uuid}}">
          <img class="creator-pickrow-img" src="{{img}}" alt="">
          <span class="creator-pickrow-name">{{name}}</span>
          {{#if active}}<i class="creator-pickrow-tick fa-solid fa-check"></i>{{/if}}
        </button>
      </li>
      {{else}}
      <p class="creator-empty">{{localize "sogrom-dnd5e-character-creator.step.spells.empty"}}</p>
      {{/each}}
    </ul>
  </div>

  <!-- Sidebar: focused spell (scrolls), with the running tally pinned at the bottom -->
  <div class="creator-pick-desc">
    <div class="creator-pick-desc-scroll">
    {{#if focused}}
    <article class="creator-detail">
      <header class="creator-detail-head">
        <img class="creator-detail-img" src="{{focused.img}}" alt="">
        <div>
          <h2>{{focused.name}}</h2>
          <p class="creator-spell-meta">
            {{focused.school}}{{#if focused.components}} · {{focused.components}}{{/if}}
            {{#if focused.isConcentration}} · {{localize "sogrom-dnd5e-character-creator.step.spells.concentration"}}{{/if}}
            {{#if focused.isRitual}} · {{localize "sogrom-dnd5e-character-creator.step.spells.ritual"}}{{/if}}
          </p>
        </div>
      </header>

      <button type="button" class="creator-btn {{#if focused.active}}creator-btn-danger{{else}}creator-btn-primary{{/if}}"
              data-action="stepAction" data-step-action="pick-spell"
              data-uuid="{{focused.uuid}}" data-level="{{focused.level}}"
              {{#if focused.disabled}}disabled{{/if}}>
        {{#if focused.active}}
        <i class="fa-solid fa-minus"></i> {{localize "sogrom-dnd5e-character-creator.step.spells.remove"}}
        {{else}}
        <i class="fa-solid fa-plus"></i> {{localize "sogrom-dnd5e-character-creator.step.spells.add"}}
        {{/if}}
      </button>

      <div class="creator-detail-body">{{{focused.description}}}</div>
    </article>
    {{else}}
    <div class="creator-pick-empty">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
      <h2>{{localize "sogrom-dnd5e-character-creator.step.spells.label"}}</h2>
      <p>{{localize "sogrom-dnd5e-character-creator.step.spells.selectHint"}}</p>
    </div>
    {{/if}}
    </div>

    <!-- Running tally of everything picked so far, grouped by level. -->
    <div class="creator-spell-selected">
      <span class="creator-spell-selected-label">{{localize "sogrom-dnd5e-character-creator.step.spells.selected"}}</span>
      {{#if hasSelected}}
      <div class="creator-spell-groups">
        {{#if selectedCantrips.length}}
        <div class="creator-spell-group">
          <span class="creator-spell-group-label">{{localize "sogrom-dnd5e-character-creator.step.spells.cantrips"}}</span>
          <ul class="creator-spell-chips">
            {{#each selectedCantrips}}
            <li><a class="content-link creator-spell-chip" data-uuid="{{uuid}}" data-link data-tooltip="{{ccItemTooltip uuid}}"><img src="{{img}}" alt="">{{name}}</a></li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
        {{#if selectedSpells.length}}
        <div class="creator-spell-group">
          <span class="creator-spell-group-label">{{localize "sogrom-dnd5e-character-creator.step.spells.level1"}}</span>
          <ul class="creator-spell-chips">
            {{#each selectedSpells}}
            <li><a class="content-link creator-spell-chip" data-uuid="{{uuid}}" data-link data-tooltip="{{ccItemTooltip uuid}}"><img src="{{img}}" alt="">{{name}}</a></li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
      </div>
      {{else}}
      <span class="creator-spell-selected-empty">{{localize "sogrom-dnd5e-character-creator.step.spells.selectedNone"}}</span>
      {{/if}}
    </div>
  </div>

  {{else}}
  <div class="creator-pick-empty creator-spells-none">
    <i class="fa-solid fa-ban"></i>
    <h2>{{localize "sogrom-dnd5e-character-creator.step.spells.label"}}</h2>
    <p>{{hint}}</p>
  </div>
  {{/if}}
</section>
