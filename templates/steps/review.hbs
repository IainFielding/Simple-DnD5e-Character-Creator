<section class="creator-review">
  <p class="creator-review-intro">{{localize "sogrom-dnd5e-character-creator.step.review.intro" name=name}}</p>

  <div class="creator-review-abilities">
    <h2>{{localize "sogrom-dnd5e-character-creator.step.abilities.label"}}
      <small>({{method}})</small></h2>
    <ul class="creator-score-strip">
      {{#each abilities}}
      <li class="creator-score">
        <span class="creator-score-abbr">{{abbr}}</span>
        <span class="creator-score-value">{{value}}</span>
        <span class="creator-score-mod">{{modifier}}</span>
        {{#if bonus}}<span class="creator-score-bonus" data-tooltip="{{bonusTip}}">{{bonus}}</span>{{/if}}
      </li>
      {{/each}}
    </ul>
  </div>

  <div class="creator-review-columns">
  {{#each sections}}
  <div class="creator-review-block creator-review-origin {{#unless chosen}}is-empty{{/unless}}">
    <header class="creator-review-origin-head">
      <span class="creator-review-kind">{{kind}}</span>
      {{#if chosen}}
      <img class="creator-review-origin-img" src="{{img}}" alt="">
      <h2>{{name}}</h2>
      {{else}}
      <h2 class="is-muted">{{empty}}</h2>
      {{/if}}
    </header>

    {{#if chosen}}
    {{#if rows.length}}
    <ul class="creator-trait-list">
      {{#each rows}}
      <li class="creator-trait {{#if empty}}is-empty{{/if}}">
        <span class="creator-trait-label">{{title}}</span>
        <span class="creator-trait-value">
          {{#if empty}}<em>{{localize "sogrom-dnd5e-character-creator.step.review.notChosen"}}</em>
          {{else}}
            {{#each values}}
            {{#if uuid}}<a class="content-link creator-item-link" data-uuid="{{uuid}}" data-link data-tooltip=" ">{{#if img}}<img src="{{img}}" alt="">{{/if}}{{name}}</a>{{else}}<span class="creator-review-val">{{name}}</span>{{/if}}
            {{/each}}
          {{/if}}
        </span>
      </li>
      {{/each}}
    </ul>
    {{/if}}

    {{#if spells.hasAny}}
    <div class="creator-review-sub">
      <h3>{{localize "sogrom-dnd5e-character-creator.step.spells.label"}}</h3>
      {{#if spells.cantrips.length}}
      <h4>{{localize "sogrom-dnd5e-character-creator.step.spells.cantrips"}}</h4>
      <ul class="creator-review-spells">
        {{#each spells.cantrips}}<li><a class="content-link" data-uuid="{{uuid}}" data-link data-tooltip=" "><img src="{{img}}" alt="">{{name}}</a></li>{{/each}}
      </ul>
      {{/if}}
      {{#if spells.level1.length}}
      <h4>{{localize "sogrom-dnd5e-character-creator.step.spells.level1"}}</h4>
      <ul class="creator-review-spells">
        {{#each spells.level1}}<li><a class="content-link" data-uuid="{{uuid}}" data-link data-tooltip=" "><img src="{{img}}" alt="">{{name}}</a></li>{{/each}}
      </ul>
      {{/if}}
    </div>
    {{/if}}

    {{#if equipment.hasAny}}
    <div class="creator-review-sub">
      <h3>{{localize "sogrom-dnd5e-character-creator.equipment.heading"}}</h3>
      <ul class="creator-review-spells">
        {{#each equipment.items}}<li>{{#if uuid}}<a class="content-link" data-uuid="{{uuid}}" data-link data-tooltip=" ">{{#if img}}<img src="{{img}}" alt="">{{/if}}{{name}}</a>{{else}}{{#if img}}<img src="{{img}}" alt="">{{/if}}{{name}}{{/if}}{{#if count}} ×{{count}}{{/if}}</li>{{/each}}
        {{#if equipment.gold}}<li><i class="fa-solid fa-coins"></i> {{equipment.gold}}</li>{{/if}}
      </ul>
    </div>
    {{/if}}
    {{/if}}
  </div>
  {{/each}}
  </div>

  {{#if details.hasAny}}
  <div class="creator-review-block">
    <h2>{{localize "sogrom-dnd5e-character-creator.step.details.label"}}</h2>
    {{#if details.tags.length}}
    <ul class="creator-trait-list">
      {{#each details.tags}}
      <li class="creator-trait">
        <span class="creator-trait-label">{{label}}</span>
        <span class="creator-trait-value">{{value}}</span>
      </li>
      {{/each}}
    </ul>
    {{/if}}
    {{#each details.texts}}
    <div class="creator-review-text">
      <h3>{{label}}</h3>
      <p>{{value}}</p>
    </div>
    {{/each}}
  </div>
  {{/if}}
</section>
