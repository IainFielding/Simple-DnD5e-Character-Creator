{{!--
  The level-up Class step (lvl-class-step.mjs): the creator's pick-list + detail layout. One
  scrolling list with the actor's own classes first (tagged "Level 5 → 6") and, when the world
  allows multiclassing, the takeable new classes beneath a group heading (prerequisite failures
  locked, their tooltip naming the missing ability). Rows fire pick-levelup-class; picking one
  builds the level-up pipeline and unlocks Next.
--}}
<section class="creator-pick creator-pick--solo levelup-class-pick">
  <!-- Left column: the class list -->
  <div class="creator-pick-side">
    <ul class="creator-picklist">
      {{#if hasAddable}}
      <li class="levelup-class-group">{{localize "sogrom-dnd5e-character-creator.levelup.step.class.yours"}}</li>
      {{/if}}
      {{#each existing}}
      <li>
        <button type="button" class="creator-pickrow {{#if selected}}is-selected{{/if}}"
                data-action="stepAction" data-step-action="pick-levelup-class"
                data-kind="existing" data-id="{{id}}" data-name="{{name}}">
          <img class="creator-pickrow-img" src="{{img}}" alt="">
          <span class="creator-pickrow-name">{{name}}</span>
          <span class="creator-pickrow-tag">{{tag}}</span>
          {{#if selected}}<i class="creator-pickrow-tick fa-solid fa-check" inert></i>{{/if}}
        </button>
      </li>
      {{/each}}

      {{#if hasAddable}}
      <li class="levelup-class-group">{{localize "sogrom-dnd5e-character-creator.levelup.step.class.multiclass"}}</li>
      {{#each addable}}
      <li>
        <button type="button"
                class="creator-pickrow {{#if selected}}is-selected{{/if}} {{#if disabled}}is-disabled{{/if}}"
                data-action="stepAction" data-step-action="pick-levelup-class"
                data-kind="new" data-uuid="{{uuid}}" data-name="{{name}}"
                {{#if disabled}}aria-disabled="true" data-tooltip="{{reason}}"{{/if}}>
          <img class="creator-pickrow-img" src="{{img}}" alt="">
          <span class="creator-pickrow-name">{{name}}</span>
          {{#if disabled}}<i class="creator-pickrow-tick fa-solid fa-lock" inert></i>
          {{else}}<span class="creator-pickrow-tag">{{tag}}</span>{{/if}}
          {{#if selected}}<i class="creator-pickrow-tick fa-solid fa-check" inert></i>{{/if}}
        </button>
      </li>
      {{/each}}
      {{/if}}
    </ul>
  </div>

  <!-- Right column: the selected class's description -->
  <div class="creator-pick-desc">
    {{#if hasSelection}}
    <article class="creator-detail">
      <header class="creator-detail-head">
        <img class="creator-detail-img" src="{{detail.img}}" alt="">
        <h2>{{detail.name}}</h2>
      </header>
      <div class="creator-detail-body">{{{detail.enriched}}}</div>

      {{#each groups}}
      <section class="creator-adv-block">
        <h3 class="creator-adv-heading">{{heading}}</h3>

        {{#if tags.length}}
        <ul class="creator-trait-list">
          {{#each tags}}
          <li class="creator-trait">
            <span class="creator-trait-label">{{label}}</span>
            <span class="creator-trait-value">{{value}}</span>
          </li>
          {{/each}}
        </ul>
        {{/if}}

        {{#if items.length}}
        <div class="creator-grant-list">
          {{#each items}}
          <div class="creator-grant">
            <img class="creator-grant-icon" src="{{img}}" alt="">
            <a class="content-link" data-uuid="{{uuid}}" data-link data-tooltip="{{ccItemTooltip uuid}}">{{name}}</a>
            {{#if level}}<span class="creator-grant-tag">{{localize "sogrom-dnd5e-character-creator.step.class.levelTag" level=level}}</span>{{/if}}
          </div>
          {{/each}}
        </div>
        {{/if}}
      </section>
      {{/each}}
    </article>
    {{else}}
    <div class="creator-pick-empty">
      <i class="fa-solid fa-chess-rook"></i>
      <h2>{{localize "sogrom-dnd5e-character-creator.levelup.step.class.label"}}</h2>
      <p>{{localize "sogrom-dnd5e-character-creator.levelup.step.class.hint"}}</p>
    </div>
    {{/if}}
  </div>
</section>
