{{!-- Level-up HP block (rendered inside level.hbs). One row per gained level: average / max /
      roll / manual, per the GM's levelUpHpMode setting (allowMax/allowRoll/allowManual flags).
      Buttons fire hp* actions (hpAverage, hpRoll, hpManual); data from hp-step.mjs sectionsAt(). --}}
<section class="creator-levelup creator-levelup-hp">
  <p class="creator-step-intro">{{intro}}</p>

  {{#each rows}}
  <div class="creator-hp-row" data-index="{{index}}">
    {{#if levelLabel}}<header class="creator-hp-head"><span class="creator-hp-level">{{levelLabel}}</span></header>{{/if}}

    <div class="creator-hp-controls">
      <div class="creator-hp-buttons">
        <button type="button" class="creator-hp-btn {{#if isAverage}}is-selected{{/if}}"
                data-action="stepAction" data-step-action="hpAverage" data-index="{{index}}">
          <span class="creator-hp-btn-label">{{localize "sogrom-dnd5e-character-creator.levelup.step.hp.average"}}</span>
          <span class="creator-hp-btn-value">+{{average}}</span>
        </button>

        {{#if ../allowMax}}
        <button type="button" class="creator-hp-btn {{#if isMax}}is-selected{{/if}}"
                data-action="stepAction" data-step-action="hpMax" data-index="{{index}}">
          <span class="creator-hp-btn-label">{{localize "sogrom-dnd5e-character-creator.levelup.step.hp.max"}}</span>
          <span class="creator-hp-btn-value">+{{max}}</span>
        </button>
        {{/if}}

        {{#if ../allowRoll}}
        <button type="button" class="creator-hp-btn {{#if isRoll}}is-selected{{/if}}"
                data-action="stepAction" data-step-action="hpRoll" data-index="{{index}}">
          <span class="creator-hp-btn-label"><i class="fa-solid fa-dice-d20"></i> {{rollLabel}}</span>
          <span class="creator-hp-btn-value">{{#if rolled}}+{{rolled}}{{else}}<i class="fa-solid fa-dice"></i>{{/if}}</span>
        </button>
        {{/if}}
      </div>

      <label class="creator-hp-result {{#if isManual}}is-manual{{/if}}">
        <span class="creator-hp-result-label">{{localize "sogrom-dnd5e-character-creator.levelup.step.hp.gained"}}</span>
        {{#if ../allowManual}}
        <input type="number" class="creator-hp-input" min="1" max="{{max}}" value="{{current}}"
               data-step-change="hpManual" data-index="{{index}}">
        {{else}}
        <input type="number" class="creator-hp-input" value="{{current}}" readonly tabindex="-1">
        {{/if}}
        <span class="creator-hp-con">{{conBreakdown}}</span>
      </label>
    </div>
  </div>
  {{/each}}
</section>
