{{!--
  The multiclass class picker (class-picker.mjs): the creation class step's list + description
  layout in a small framed window. Rows fire data-action="pickClass"; a locked row (prereqs
  unmet under the "prereq" multiclass mode) keeps its tooltip but ignores clicks. The footer's
  Multiclass button confirms; Cancel (or closing the window) resolves null.
--}}
<section class="creator-pick creator-pick--solo sogrom-mcpick">
  <!-- Left column: the class list -->
  <div class="creator-pick-side">
    <ul class="creator-picklist">
      {{#each cards}}
      <li>
        <button type="button"
                class="creator-pickrow {{#if selected}}is-selected{{/if}} {{#if disabled}}is-disabled{{/if}}"
                data-action="pickClass" data-uuid="{{uuid}}" data-name="{{name}}"
                {{#if disabled}}aria-disabled="true" data-tooltip="{{reason}}"{{/if}}>
          <img class="creator-pickrow-img" src="{{img}}" alt="">
          <span class="creator-pickrow-name">{{name}}</span>
          {{#if disabled}}<i class="creator-pickrow-tick fa-solid fa-lock" inert></i>{{/if}}
          {{#if selected}}<i class="creator-pickrow-tick fa-solid fa-check" inert></i>{{/if}}
        </button>
      </li>
      {{else}}
      <p class="creator-empty">{{localize "sogrom-dnd5e-character-creator.levelup.multiclass.noneAvailable"}}</p>
      {{/each}}
    </ul>
  </div>

  <!-- Right column: the selected class's description -->
  <div class="creator-pick-desc">
    {{#if hasSelection}}
    <article class="creator-detail">
      <header class="creator-detail-head">
        <img class="creator-detail-img" src="{{detail.img}}" alt="">
        <h2>{{detail.name}}</h2>
      </header>
      <div class="creator-detail-body">{{{detail.enriched}}}</div>

      {{#each groups}}
      <section class="creator-adv-block">
        <h3 class="creator-adv-heading">{{heading}}</h3>

        {{#if tags.length}}
        <ul class="creator-trait-list">
          {{#each tags}}
          <li class="creator-trait">
            <span class="creator-trait-label">{{label}}</span>
            <span class="creator-trait-value">{{value}}</span>
          </li>
          {{/each}}
        </ul>
        {{/if}}

        {{#if items.length}}
        <div class="creator-grant-list">
          {{#each items}}
          <div class="creator-grant">
            <img class="creator-grant-icon" src="{{img}}" alt="">
            <a class="content-link" data-uuid="{{uuid}}" data-link data-tooltip="{{ccItemTooltip uuid}}">{{name}}</a>
            {{#if level}}<span class="creator-grant-tag">{{localize "sogrom-dnd5e-character-creator.step.class.levelTag" level=level}}</span>{{/if}}
          </div>
          {{/each}}
        </div>
        {{/if}}
      </section>
      {{/each}}
    </article>
    {{else}}
    <div class="creator-pick-empty">
      <i class="fa-solid fa-chess-rook"></i>
      <h2>{{localize "sogrom-dnd5e-character-creator.levelup.multiclass.pickerTitle"}}</h2>
      <p>{{localize "sogrom-dnd5e-character-creator.common.selectHint"}}</p>
    </div>
    {{/if}}
  </div>
</section>

<footer class="sogrom-mcpick-foot">
  <button type="button" class="creator-btn creator-btn-ghost" data-action="cancel">
    {{localize "sogrom-dnd5e-character-creator.common.cancel"}}
  </button>
  <button type="button" class="creator-btn creator-btn-primary" data-action="confirm"
          {{#unless hasSelection}}disabled{{/unless}}>
    <i class="fa-solid fa-chess-rook" inert></i>
    {{localize "sogrom-dnd5e-character-creator.levelup.multiclass.pick"}}
  </button>
</footer>
